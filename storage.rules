rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /orders/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null && 
        (firestore.get(/databases/ai-studio-e1541e56-d160-4b1c-ae77-486b5c04a5e0/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "manikandanprabhu37@gmail.com" && request.auth.token.email_verified == true));
    }
  }
}
